# Campus Capital — Environment Variables
#
# The app runs fully in DEMO MODE with rich mock data when these are not set.
# Add your Supabase project credentials to enable real auth + persistence.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: server-side only (never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: enables the live Capital Coach AI tutor.
# Without a key, Capital Coach uses a high-quality built-in response engine.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: enables LIVE market prices in the trading simulator.
# Free key from https://finnhub.io. Without it, the simulator uses realistic
# simulated prices. (Educational paper-trading only — fake money, no real orders.)
FINNHUB_API_KEY=

# Optional: override the Capital Coach model (default: claude-opus-4-8).
# e.g. claude-haiku-4-5 for much lower cost at scale.
CC_COACH_MODEL=
